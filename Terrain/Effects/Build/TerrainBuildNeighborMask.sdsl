namespace Terrain
{
    shader TerrainBuildNeighborMask : ComputeShaderBase
    {
        struct TerrainBuildChunkNode
        {
            int4 NodeInfo;
            int4 StreamInfo;
        };

        stage RWStructuredBuffer<TerrainBuildChunkNode> InstanceBuffer;
        stage Texture2D<uint> LodMap;
        stage int InstanceCount;
        stage int LodMapWidth;
        stage int LodMapHeight;

        uint LoadNeighborLod(int x, int y, uint fallbackLod)
        {
            if ((uint)x >= (uint)LodMapWidth || (uint)y >= (uint)LodMapHeight)
            {
                return fallbackLod;
            }

            return LodMap.Load(int3(x, y, 0));
        }

        override void Compute()
        {
            uint instanceIndex = streams.DispatchThreadId.x;
            if (instanceIndex >= (uint)InstanceCount)
            {
                return;
            }

            TerrainBuildChunkNode node = InstanceBuffer[instanceIndex];
            int4 nodeInfo = node.NodeInfo;
            uint currentLod = (uint)nodeInfo.z;
            int lodScale = 1 << nodeInfo.z;
            int originX = nodeInfo.x * lodScale;
            int originY = nodeInfo.y * lodScale;

            uint leftLod = LoadNeighborLod(originX - 1, originY, currentLod);
            uint rightLod = LoadNeighborLod(originX + lodScale, originY, currentLod);
            uint topLod = LoadNeighborLod(originX, originY - 1, currentLod);
            uint bottomLod = LoadNeighborLod(originX, originY + lodScale, currentLod);

            uint leftDelta = leftLod > currentLod ? leftLod - currentLod : 0;
            uint rightDelta = rightLod > currentLod ? rightLod - currentLod : 0;
            uint topDelta = topLod > currentLod ? topLod - currentLod : 0;
            uint bottomDelta = bottomLod > currentLod ? bottomLod - currentLod : 0;

            uint packedMask = (leftDelta & 0xFF);
            packedMask |= (rightDelta & 0xFF) << 8;
            packedMask |= (topDelta & 0xFF) << 16;
            packedMask |= (bottomDelta & 0xFF) << 24;

            node.NodeInfo.w = (int)packedMask;
            InstanceBuffer[instanceIndex] = node;
        }
    };
}
