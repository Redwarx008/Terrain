<Window
  x:Class="Terrain.Editor.Views.MainWindow"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:Terrain.Editor.Views.Controls"
  xmlns:converters="clr-namespace:Terrain.Editor.Converters"
  Title="{Binding Title}"
  Width="1920"
  Height="1080"
  MinWidth="1280"
  MinHeight="780"
  SystemDecorations="BorderOnly"
  ExtendClientAreaToDecorationsHint="True"
  ExtendClientAreaChromeHints="NoChrome">
  <Window.Resources>
    <converters:InvertedNullToBoolConverter x:Key="InvertedNullToBool" />
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Button#CloseButton:pointerover">
      <Setter Property="Background" Value="{DynamicResource EditorWindowCloseBrush}" />
    </Style>
    <Style Selector="Button#CloseButton:pointerover TextBlock.windowButtonIcon">
      <Setter Property="Foreground" Value="{DynamicResource EditorSurfaceBrush}" />
    </Style>
  </Window.Styles>
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenProjectCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveProjectAsCommand}" />
    <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Z" Command="{Binding RedoCommand}" />
  </Window.KeyBindings>
  <DockPanel LastChildFill="True">

    <!-- ═══ Title Bar ═══ -->
    <Border DockPanel.Dock="Top" Classes="titleBar" PointerPressed="TitleBar_OnPointerPressed">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="4,0,0,0">
          <Border Width="18" Height="18" Background="{DynamicResource EditorAppIconBackgroundBrush}" CornerRadius="2">
            <TextBlock Foreground="White" FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE9D9;" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Classes="titleBarText" Text="{Binding Title}" />
        </StackPanel>

        <Grid Grid.Column="2" ColumnDefinitions="40,40,40">
          <Button Grid.Column="0" Classes="windowButton" Click="MinimizeButton_OnClick">
            <TextBlock Classes="windowButtonIcon" Text="&#xE921;" />
          </Button>
          <Button Grid.Column="1" Classes="windowButton" Click="MaximizeButton_OnClick">
            <TextBlock Classes="windowButtonIcon" Text="&#xE922;" />
          </Button>
          <Button Grid.Column="2" x:Name="CloseButton" Classes="windowButton" Click="CloseButton_OnClick">
            <TextBlock Classes="windowButtonIcon" Text="&#xE8BB;" />
          </Button>
        </Grid>
      </Grid>
    </Border>

    <!-- ═══ Toolbar Row ═══ -->
    <Border DockPanel.Dock="Top" Classes="toolbarRow">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto" VerticalAlignment="Center">
        <!-- Quick Actions (New/Open/Save) -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="1" Margin="4,0,2,0">
          <Button Classes="commandButton" Command="{Binding NewProjectCommand}">
            <TextBlock Classes="toolbarIcon" Text="&#xE710;" />
          </Button>
          <Button Classes="commandButton" Command="{Binding OpenProjectCommand}">
            <TextBlock Classes="toolbarIcon" Text="&#xE8B7;" />
          </Button>
          <Button Classes="commandButton" Command="{Binding SaveProjectCommand}">
            <TextBlock Classes="toolbarIcon" Text="&#xE74E;" />
          </Button>
        </StackPanel>

        <Border Grid.Column="1" Classes="commandDivider" Margin="2,0" />

        <!-- Undo/Redo -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="1" Margin="4,0,2,0">
          <Button Classes="commandButton" Command="{Binding UndoCommand}">
            <TextBlock Classes="toolbarIcon" Text="&#xE7A7;" />
          </Button>
          <Button Classes="commandButton" Command="{Binding RedoCommand}">
            <TextBlock Classes="toolbarIcon" Text="&#xE7A6;" />
          </Button>
        </StackPanel>

        <Border Grid.Column="3" Classes="commandDivider" Margin="2,0" />

        <!-- Menu Nav -->
        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
          <Button Classes="commandButton" Content="File" FontSize="12">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Command="{Binding NewProjectCommand}">
                  <MenuItem.Header>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="New" />
                      <TextBlock Grid.Column="1" Text="Ctrl+N" Foreground="{DynamicResource EditorTextSecondaryBrush}" FontSize="11" />
                    </Grid>
                  </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding OpenProjectCommand}">
                  <MenuItem.Header>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Open..." />
                      <TextBlock Grid.Column="1" Text="Ctrl+O" Foreground="{DynamicResource EditorTextSecondaryBrush}" FontSize="11" />
                    </Grid>
                  </MenuItem.Header>
                </MenuItem>
                <Separator />
                <MenuItem Command="{Binding SaveProjectCommand}">
                  <MenuItem.Header>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Save" />
                      <TextBlock Grid.Column="1" Text="Ctrl+S" Foreground="{DynamicResource EditorTextSecondaryBrush}" FontSize="11" />
                    </Grid>
                  </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding SaveProjectAsCommand}">
                  <MenuItem.Header>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Save As..." />
                      <TextBlock Grid.Column="1" Text="Ctrl+Shift+S" Foreground="{DynamicResource EditorTextSecondaryBrush}" FontSize="11" />
                    </Grid>
                  </MenuItem.Header>
                </MenuItem>
                <Separator />
                <MenuItem Header="Export">
                  <MenuItem Header="Terrain..." Command="{Binding ExportTerrainCommand}" />
                  <MenuItem Header="Biome Config..." Command="{Binding ExportBiomeConfigCommand}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
          <Button Classes="commandButton" Content="Edit" FontSize="12">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Command="{Binding UndoCommand}">
                  <MenuItem.Header>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Undo" />
                      <TextBlock Grid.Column="1" Text="Ctrl+Z" Foreground="{DynamicResource EditorTextSecondaryBrush}" FontSize="11" />
                    </Grid>
                  </MenuItem.Header>
                </MenuItem>
                <MenuItem Command="{Binding RedoCommand}">
                  <MenuItem.Header>
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="Redo" />
                      <TextBlock Grid.Column="1" Text="Ctrl+Y" Foreground="{DynamicResource EditorTextSecondaryBrush}" FontSize="11" />
                    </Grid>
                  </MenuItem.Header>
                </MenuItem>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
          <Button Classes="commandButton" Content="View" FontSize="12">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="Side Nav" IsChecked="{Binding IsSideNavVisible, Mode=TwoWay}" ToggleType="CheckBox" />
                <MenuItem Header="Asset Browser" IsChecked="{Binding IsAssetBrowserVisible, Mode=TwoWay}" ToggleType="CheckBox" />
                <MenuItem Header="Inspector" IsChecked="{Binding IsInspectorVisible, Mode=TwoWay}" ToggleType="CheckBox" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
          <Button Classes="commandButton" Content="Select" FontSize="12" />
          <Button Classes="commandButton" Content="Tools" FontSize="12" />
          <Button Classes="commandButton" Content="Help" FontSize="12">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="About" Command="{Binding OpenHelpCommand}" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>

        <!-- Project Name (right aligned) -->
        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,8,0">
          <TextBlock Classes="panelHint" Text="{Binding ProjectName}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ Main Workspace: Mode | Viewport+AssetBrowser | Inspector ═══ -->
    <Grid Margin="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="4" />
        <ColumnDefinition Width="360" MinWidth="320" MaxWidth="520" />
      </Grid.ColumnDefinitions>

      <!-- ─── SideNavBar (Modes) ─── -->
      <Border Grid.Column="0" Classes="editorPanel,modePanel" BorderThickness="0,0,1,0" IsVisible="{Binding IsSideNavVisible}" Width="80">
        <Grid RowDefinitions="Auto,*">
          <!-- Mode Header -->
          <StackPanel HorizontalAlignment="Center" Margin="0,8,0,2">
            <TextBlock FontSize="11" FontWeight="Bold" Text="MODES" HorizontalAlignment="Center" Foreground="{DynamicResource EditorTextPrimaryBrush}" />
          </StackPanel>

          <!-- Mode List -->
          <ListBox
            Grid.Row="1"
            Classes="modeList"
            ItemsSource="{Binding Modes}"
            SelectedItem="{Binding SelectedModeOption}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel HorizontalAlignment="Center" Spacing="2">
                  <TextBlock Classes="modeIcon" HorizontalAlignment="Center" Text="{Binding Glyph}" />
                  <TextBlock Classes="modeLabel" HorizontalAlignment="Center" Text="{Binding Label}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- ─── Center: Viewport + Asset Browser ─── -->
      <Grid Grid.Column="1" RowDefinitions="*,Auto">

        <!-- Viewport Area -->
        <Border Grid.Row="0" Classes="editorPanel,viewportPanel" BorderThickness="0,0,0,1" ClipToBounds="True">
          <Grid RowDefinitions="Auto,*">
            <!-- Viewport Toolbar (top row) -->
            <Border Classes="viewportToolbar">
              <Grid ColumnDefinitions="*,Auto">

                <!-- View Dropdown -->
                <ComboBox
                  Grid.Column="1"
                  Classes="metroCombo"
                  MinWidth="90"
                  ItemsSource="{Binding SceneViewModes}"
                  SelectedItem="{Binding SelectedSceneViewMode}" />
              </Grid>
            </Border>

            <!-- 3D Viewport -->
            <Grid Grid.Row="1" ClipToBounds="True">
              <controls:NativeStrideViewportControl
                ViewportHost="{Binding Viewport.ViewportHost}"
                Background="{DynamicResource EditorViewportDarkBackgroundBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

              <Canvas IsHitTestVisible="False" ClipToBounds="True">
                <StackPanel Canvas.Left="20" Canvas.Bottom="20" Spacing="2">
                  <TextBlock Classes="axisZ" Text="Z" />
                  <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10">
                    <TextBlock Classes="axisY" Text="Y" />
                    <TextBlock Grid.Column="1" Classes="axisX" Text="X" />
                  </Grid>
                </StackPanel>
              </Canvas>

              <!-- Viewport Stats -->
              <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="12" Spacing="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Foreground="{DynamicResource EditorViewportStatTextBrush}" FontSize="10" Text="FPS: 120" />
                  <TextBlock Foreground="{DynamicResource EditorViewportStatTextBrush}" FontSize="10" Text="Tris: 1.2M" />
                  <TextBlock Foreground="{DynamicResource EditorViewportStatTextBrush}" FontSize="10" Text="Grid: 10m" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>

        <!-- ─── Asset Browser ─── -->
        <Border Grid.Row="1" Classes="editorPanel,assetBrowserPanel" BorderThickness="0,1,0,0" ClipToBounds="True" IsVisible="{Binding IsAssetBrowserVisible}">
          <Grid RowDefinitions="Auto,*">
            <!-- Asset Tab Bar -->
            <Border Classes="viewportToolbar" Background="{DynamicResource EditorAssetTabBackgroundBrush}" BorderThickness="0">
              <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="0">
                  <Button x:Name="AssetTabTextures" Classes="assetTabActive" Command="{Binding SelectAssetCategoryCommand}" CommandParameter="Textures">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Classes="assetTabIcon" Text="&#xE71B;" />
                      <TextBlock Text="Textures" />
                    </StackPanel>
                  </Button>
                  <Button x:Name="AssetTabMeshes" Classes="assetTab" Command="{Binding SelectAssetCategoryCommand}" CommandParameter="Meshes">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Classes="assetTabIcon" Text="&#xE80A;" />
                      <TextBlock Text="Meshes" />
                    </StackPanel>
                  </Button>
                  <Button x:Name="AssetTabFoliage" Classes="assetTab" Command="{Binding SelectAssetCategoryCommand}" CommandParameter="Foliage">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Classes="assetTabIcon" Text="&#xEC7A;" />
                      <TextBlock Text="Foliage" />
                    </StackPanel>
                  </Button>
                  <Button x:Name="AssetTabPrefabs" Classes="assetTab" Command="{Binding SelectAssetCategoryCommand}" CommandParameter="Prefabs">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Classes="assetTabIcon" Text="&#xE7B8;" />
                      <TextBlock Text="Prefabs" />
                    </StackPanel>
                  </Button>
                </StackPanel>

                <Border Grid.Column="1" />

                <!-- Search -->
                <TextBox Grid.Column="2" Classes="searchBox" Text="{Binding AssetSearchText}" Watermark="Search assets..." Width="180" Margin="0,0,4,0" VerticalAlignment="Center">
                  <TextBox.InnerLeftContent>
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource EditorTextSecondaryBrush}" Text="&#xE71E;" VerticalAlignment="Center" Margin="0,0,6,0" />
                  </TextBox.InnerLeftContent>
                </TextBox>
                <Button Grid.Column="3" Classes="commandButton" Padding="4" VerticalAlignment="Center" Command="{Binding SetGridViewCommand}">
                  <TextBlock Classes="viewToggleIcon" Text="&#xE71C;" />
                </Button>
                <Button Grid.Column="4" Classes="commandButton" Padding="4" VerticalAlignment="Center" Command="{Binding ToggleAssetBrowserCommand}">
                  <TextBlock Classes="viewToggleIcon" Text="&#xE70E;" />
                </Button>
              </Grid>
            </Border>

            <!-- Asset Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <ListBox x:Name="AssetListBox" Classes="assetTileList" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemsSource="{Binding AssetItems}" SelectedItem="{Binding SelectedAssetItem, Mode=TwoWay}">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="assetTile">
                      <Border.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="Delete" Command="{Binding $parent[Window].DataContext.DeleteAssetItemCommand}" CommandParameter="{Binding}" />
                        </ContextMenu>
                      </Border.ContextMenu>
                      <Grid RowDefinitions="96,Auto">
                        <Border Classes="assetPreview" Background="{Binding PreviewBackground}">
                          <Panel>
                            <TextBlock Classes="assetPreviewGlyph" Foreground="{Binding PreviewForeground}" Text="{Binding IconGlyph}"
                                       IsVisible="{Binding PreviewImage, Converter={StaticResource InvertedNullToBool}}" />
                            <Image Source="{Binding PreviewImage}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
                          </Panel>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Margin="4,6,4,4" Foreground="{DynamicResource EditorTextPrimaryBrush}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>

      <GridSplitter Grid.Column="2"
                    Width="4"
                    HorizontalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    Background="Transparent"
                    BorderBrush="{DynamicResource EditorPanelBorderBrush}"
                    BorderThickness="1,0,0,0"
                    ShowsPreview="False"
                    IsVisible="{Binding IsInspectorVisible}" />

      <!-- ─── Right Inspector Panel ─── -->
      <Border Grid.Column="3" Classes="editorPanel,inspectorPanel" BorderThickness="1,0,0,0" ClipToBounds="True" IsVisible="{Binding IsInspectorVisible}">
        <Grid RowDefinitions="Auto,*,Auto">
          <!-- Inspector Header -->
          <Border Classes="inspectorHeader">
            <TextBlock Classes="sectionTitle" VerticalAlignment="Center" Text="{Binding SelectedModeDisplayName, StringFormat='{}{0} Tool'}" />
          </Border>

          <!-- Inspector Content (scrollable) -->
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">

              <!-- ═══ Current Tool Section ═══ -->
              <Border Padding="10,10,10,0" IsVisible="{Binding HasTools}">
                <StackPanel Spacing="8">
                  <TextBlock Classes="sectionLabel" Text="CURRENT TOOL" />
                  <ListBox
                    Classes="toolList"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ItemsSource="{Binding Tools}"
                    SelectedItem="{Binding SelectedTool}">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center" Spacing="2" Margin="2">
                          <TextBlock Classes="toolIcon" HorizontalAlignment="Center" Text="{Binding Glyph}" />
                          <TextBlock Classes="toolLabel" HorizontalAlignment="Center" Text="{Binding Label}" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Border>

              <!-- ═══ Sculpt Mode Inspector ═══ -->
              <StackPanel IsVisible="{Binding IsSculptMode}" Spacing="0">
                <!-- Brush Settings -->
                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="sectionLabel" Text="BRUSH SETTINGS" />

                    <!-- Radius -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Diameter" />
                        <Slider Minimum="1" Maximum="1000" Value="{Binding BrushParams.Size}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding BrushParams.Size, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- Strength -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Strength" />
                        <Slider Minimum="0" Maximum="1" Value="{Binding BrushParams.Strength}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding BrushParams.Strength, StringFormat='{}{0:F2}'}" VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- Falloff -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Falloff" />
                        <Slider Minimum="0" Maximum="1" Value="{Binding BrushParams.Falloff}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding BrushParams.Falloff, StringFormat='{}{0:F2}'}" VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- Brush Alpha -->
                    <StackPanel Spacing="4" Margin="0,4,0,0">
                      <TextBlock Classes="fieldLabel" Text="Brush Alpha" />
                      <Grid ColumnDefinitions="40,*,24" ColumnSpacing="8">
                        <Border Classes="brushPreviewFrame">
                          <Ellipse Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Fill>
                              <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                <GradientStop Color="#FF000000" Offset="0.0" />
                                <GradientStop Color="#FF6D6D6D" Offset="0.42" />
                                <GradientStop Color="#FFF2F2F2" Offset="1.0" />
                              </RadialGradientBrush>
                            </Ellipse.Fill>
                          </Ellipse>
                        </Border>
                        <TextBlock Grid.Column="1" Classes="panelHint" VerticalAlignment="Center" Text="Soft_Round_01" />
                        <Button Grid.Column="2" Classes="commandButton" Padding="2">
                          <TextBlock Classes="chevronIcon" Text="&#xE712;" />
                        </Button>
                      </Grid>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Advanced -->
                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="sectionLabel" Text="ADVANCED" />
                    <CheckBox Content="Use Target Value" IsChecked="True" />
                    <CheckBox Content="Auto-LOD" IsChecked="False" />
                    <CheckBox Content="Show Brush Wireframe" IsChecked="True" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- ═══ Biome Mode Inspector ═══ -->
              <StackPanel IsVisible="{Binding IsPaintMode}" Spacing="0">
                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="sectionLabel" Text="BRUSH SETTINGS" />
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Diameter" />
                        <Slider Minimum="1" Maximum="200" Value="{Binding BrushParams.Size}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding BrushParams.Size, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Strength" />
                        <Slider Minimum="0" Maximum="1" Value="{Binding BrushParams.Strength}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding BrushParams.Strength, StringFormat='{}{0:F2}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Falloff" />
                        <Slider Minimum="0" Maximum="1" Value="{Binding BrushParams.Falloff}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding BrushParams.Falloff, StringFormat='{}{0:F2}'}" VerticalAlignment="Bottom" />
                    </Grid>
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- ═══ Foliage Mode Inspector ═══ -->
              <StackPanel IsVisible="{Binding IsFoliageMode}" Spacing="0">
                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="sectionLabel" Text="BRUSH SETTINGS" />
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Diameter" />
                        <Slider Minimum="1" Maximum="200" Value="{Binding BrushParams.Size}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding BrushParams.Size, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Density" />
                        <Slider Minimum="0" Maximum="1" Value="0.65" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="0.65" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Randomness" />
                        <Slider Minimum="0" Maximum="1" Value="0.30" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="0.30" VerticalAlignment="Bottom" />
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="sectionLabel" Text="FOLIAGE SET" />
                    <ComboBox Classes="metroCombo" SelectedIndex="0">
                      <ComboBoxItem Content="Tree - Pine_Tree_01" />
                      <ComboBoxItem Content="Bush - Bush_01" />
                      <ComboBoxItem Content="Grass - Grass_Clump_A" />
                    </ComboBox>
                  </StackPanel>
                </Border>

                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="sectionLabel" Text="PLACEMENT" />
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Min Scale" />
                        <Slider Minimum="0.2" Maximum="2" Value="0.75" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="0.75" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Max Scale" />
                        <Slider Minimum="0.2" Maximum="3" Value="1.40" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="1.40" VerticalAlignment="Bottom" />
                    </Grid>
                    <CheckBox Content="Align To Normal" IsChecked="True" />
                    <CheckBox Content="Random Rotation" IsChecked="True" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- ═══ Settings Mode Inspector ═══ -->
              <StackPanel IsVisible="{Binding IsSettingsMode}" Spacing="0">
                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="sectionLabel" Text="TERRAIN" />
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Height Scale" />
                        <Slider Minimum="1" Maximum="1000" Value="{Binding Settings.HeightScale}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding Settings.HeightScale, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>
                  </StackPanel>
                </Border>
              </StackPanel>

              <!-- ═══ Biome Panels (Biome mode) ═══ -->
              <StackPanel IsVisible="{Binding IsBiomeVisible}" Spacing="0">
                <Border Classes="inspectorSection" Padding="10,10">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="sectionLabel" Text="BIOME LAYERS" />
                        <TextBlock Classes="panelHint" Text="{Binding Biome.SelectedBiomeLayerSummary}" />
                      </StackPanel>
                      <CheckBox Grid.Column="1" Content="Mask" IsChecked="{Binding Biome.ShowMaskOverlay}" VerticalAlignment="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                      <ComboBox Grid.Column="0"
                                Classes="metroCombo,biomeSoftCombo"
                                ItemsSource="{Binding Biome.Biomes}"
                                SelectedItem="{Binding Biome.SelectedBiome}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="14,*" ColumnSpacing="8">
                              <Border Width="10" Height="10" CornerRadius="2" Background="{Binding DebugColorBrush}" VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" />
                            </Grid>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <Button Grid.Column="1" Classes="commandButton,biomeMiniButton" Command="{Binding Biome.AddBiomeCommand}">
                        <TextBlock Classes="toolbarIcon" Text="&#xE710;" FontSize="12" />
                      </Button>
                      <Button Grid.Column="2"
                              Classes="commandButton,biomeMiniButton"
                              Command="{Binding Biome.RemoveBiomeCommand}"
                              CommandParameter="{Binding Biome.SelectedBiome.Id}">
                        <TextBlock Classes="toolbarIcon" Text="&#xE74D;" FontSize="12" />
                      </Button>
                    </Grid>

                    <Border Classes="biomeCardSurface">
                      <Grid RowDefinitions="*,Auto,Auto">
                        <ListBox Grid.Row="0"
                                 Classes="biomeLayerList"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemsSource="{Binding Biome.VisibleLayers}"
                                 SelectedItem="{Binding Biome.SelectedLayer}">
                          <ListBox.ItemTemplate>
                            <DataTemplate>
                              <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding IsEnabled}" Padding="0" VerticalAlignment="Center" />
                                <Border Classes="biomeLayerThumb">
                                  <Panel>
                                    <TextBlock Classes="assetPreviewGlyph"
                                               Text="&#xE71B;"
                                               FontSize="14"
                                               IsVisible="{Binding MaterialPreviewImage, Converter={StaticResource InvertedNullToBool}}" />
                                    <Image Source="{Binding MaterialPreviewImage}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />
                                  </Panel>
                                </Border>
                                <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                  <TextBlock Classes="panelHint" Text="{Binding ModifierCountLabel}" />
                                </StackPanel>
                              </Grid>
                            </DataTemplate>
                          </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8"
                              Margin="0,10,0,0"
                              IsVisible="{Binding Biome.SelectedLayer, Converter={x:Static ObjectConverters.IsNotNull}}">
                          <TextBox Classes="searchBox"
                                   Text="{Binding Biome.SelectedLayer.Name, Mode=TwoWay}"
                                   Watermark="Layer name" />
                          <CheckBox Grid.Column="1"
                                    Content="Enabled"
                                    IsChecked="{Binding Biome.SelectedLayer.IsEnabled}"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6" Margin="0,10,0,0">
                          <Button Classes="commandButton,biomeMiniButton" Command="{Binding Biome.MoveSelectedLayerUpCommand}">
                            <TextBlock Classes="toolbarIcon" Text="&#xE74A;" FontSize="12" />
                          </Button>
                          <Button Classes="commandButton,biomeMiniButton" Command="{Binding Biome.MoveSelectedLayerDownCommand}">
                            <TextBlock Classes="toolbarIcon" Text="&#xE74B;" FontSize="12" />
                          </Button>
                          <Button Classes="commandButton,biomeMiniButton" Command="{Binding Biome.AddLayerCommand}">
                            <TextBlock Classes="toolbarIcon" Text="&#xE710;" FontSize="14" />
                          </Button>
                          <Button Classes="commandButton,biomeMiniButton" Command="{Binding Biome.RemoveSelectedLayerCommand}">
                            <TextBlock Classes="toolbarIcon" Text="&#xE74D;" FontSize="14" />
                          </Button>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </StackPanel>
                </Border>

                <Border Classes="inspectorSection" Padding="10,10" IsVisible="{Binding Biome.SelectedLayer, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="sectionLabel" Text="MATERIAL" />
                    <Border Classes="materialPreviewCard,biomeMaterialPreviewCard">
                      <Grid ColumnDefinitions="64,*" ColumnSpacing="12">
                        <Border Classes="materialSwatch,biomeMaterialSwatch"
                                Background="{DynamicResource EditorPanelAltBackgroundBrush}">
                          <Panel>
                            <TextBlock Classes="assetPreviewGlyph"
                                       Text="&#xE71B;"
                                       FontSize="18"
                                       IsVisible="{Binding Biome.SelectedLayer.MaterialPreviewImage, Converter={StaticResource InvertedNullToBool}}" />
                            <Image Source="{Binding Biome.SelectedLayer.MaterialPreviewImage}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
                          </Panel>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Biome.SelectedLayerMaterialTitle}" FontSize="13" FontWeight="SemiBold" />
                          <TextBlock Classes="panelHint" Text="{Binding Biome.SelectedLayerMaterialDetail}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Grid>
                    </Border>
                    <ComboBox Classes="metroCombo,biomeSoftCombo"
                              ItemsSource="{Binding Biome.AvailableMaterialSlots}"
                              SelectedItem="{Binding Biome.SelectedLayerMaterialSlotOption, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                      <Button Classes="outlineButton" Content="Import" Command="{Binding ImportAssetsCommand}" />
                      <Button Grid.Column="1" Classes="outlineButton" Content="Normal" Command="{Binding ImportSelectedNormalCommand}" />
                      <Button Grid.Column="2" Classes="outlineButton" Content="Clear" Command="{Binding ClearSelectedMaterialSlotCommand}" />
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="inspectorSection" Padding="10,10" IsVisible="{Binding Biome.SelectedLayer, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <StackPanel Spacing="8" DataContext="{Binding Biome.SelectedLayer}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBlock Classes="sectionLabel" Text="MODIFIER STACK" />
                      <TextBlock Grid.Column="1" Classes="panelHint" Text="{Binding ModifierCountLabel}" />
                    </Grid>

                    <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                      <ListBox
                        Grid.Row="0"
                        Classes="biomeModifierList"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ItemsSource="{Binding Modifiers}"
                        SelectedItem="{Binding SelectedModifier}"
                        SelectedIndex="{Binding SelectedModifierIndex, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="18,28,*,70,40" ColumnSpacing="8" VerticalAlignment="Center">
                              <TextBlock Classes="biomeModifierGrip"
                                         Text="&#xE784;"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center" />
                              <CheckBox Grid.Column="1"
                                        Classes="biomeIconCheck"
                                        IsChecked="{Binding IsEnabled}" />
                              <TextBox Grid.Column="2"
                                       Classes="searchBox,biomeModifierNameBox"
                                       Text="{Binding Name, Mode=TwoWay}"
                                       VerticalContentAlignment="Center" />
                              <ComboBox Grid.Column="3"
                                        Classes="metroCombo,biomeBlendCombo"
                                        SelectedIndex="{Binding BlendModeIndex}"
                                        FontSize="11">
                                <ComboBoxItem Content="Multiply" />
                                <ComboBoxItem Content="Add" />
                                <ComboBoxItem Content="Subtract" />
                                <ComboBoxItem Content="Min" />
                                <ComboBoxItem Content="Max" />
                              </ComboBox>
                              <TextBox Grid.Column="4"
                                       Classes="valueBox,biomeModifierValueBox"
                                       IsReadOnly="True"
                                       Text="{Binding OpacityPercent}"
                                       VerticalAlignment="Center" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>

                      <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                        <ComboBox Grid.Column="0" Classes="metroCombo,biomeSoftCombo" SelectedIndex="{Binding $parent[Window].DataContext.Biome.AddModifierTypeIndex, Mode=TwoWay}">
                          <ComboBoxItem Content="Height range" />
                          <ComboBoxItem Content="Slope range" />
                          <ComboBoxItem Content="Curvature range" />
                          <ComboBoxItem Content="Direction range" />
                          <ComboBoxItem Content="Noise" />
                          <ComboBoxItem Content="Texture mask" />
                        </ComboBox>
                        <Button Grid.Column="1" Classes="commandButton,biomeMiniButton" Command="{Binding $parent[Window].DataContext.Biome.AddModifierCommand}">
                          <TextBlock Classes="toolbarIcon" Text="&#xE710;" FontSize="14" />
                        </Button>
                        <Button Grid.Column="2" Classes="commandButton,biomeMiniButton" Command="{Binding $parent[Window].DataContext.Biome.RemoveSelectedModifierCommand}">
                          <TextBlock Classes="toolbarIcon" Text="&#xE711;" FontSize="14" />
                        </Button>
                      </Grid>
                    </Grid>
                  </StackPanel>
                </Border>

                <!-- Modifier Inspector -->
                <Border Classes="inspectorSection" Padding="10,10" DataContext="{Binding Biome.SelectedLayer}" IsVisible="{Binding DataContext, RelativeSource={RelativeSource Self}, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <StackPanel Spacing="8"
                              DataContext="{Binding SelectedModifier}"
                              IsVisible="{Binding DataContext, RelativeSource={RelativeSource Self}, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Classes="sectionLabel" Text="MODIFIER SETTINGS" />

                    <!-- Modifier Name -->
                    <StackPanel Spacing="2">
                      <TextBlock Classes="fieldLabel" Text="Name" />
                      <TextBox Classes="searchBox" Text="{Binding Name, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Invert (common to most modifiers) -->
                    <CheckBox Content="Invert" IsChecked="{Binding IsInverted}" IsVisible="{Binding HasInvert}" />

                    <!-- Opacity (all modifiers) -->
                    <Grid ColumnDefinitions="*,56" ColumnSpacing="8" IsVisible="{Binding HasOpacity}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Opacity" />
                        <Slider Minimum="0" Maximum="1" Value="{Binding Opacity}" />
                      </StackPanel>
                      <TextBox Grid.Column="1"
                               Classes="valueBox"
                               IsReadOnly="True"
                               Text="{Binding OpacityPercent, StringFormat='{}{0}%'}"
                               VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- Min/Max Range (Height, Slope, Curvature, Direction, Noise) -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasMin}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Min" />
                        <Slider Minimum="{Binding MinSliderMinimum}" Maximum="{Binding MinSliderMaximum}" SmallChange="{Binding SliderSmallChange}" Value="{Binding Min}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" Text="{Binding MinDisplay, Mode=TwoWay}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasMax}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Max" />
                        <Slider Minimum="{Binding MaxSliderMinimum}" Maximum="{Binding MaxSliderMaximum}" SmallChange="{Binding SliderSmallChange}" Value="{Binding Max}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" Text="{Binding MaxDisplay, Mode=TwoWay}" VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- MinFalloff/MaxFalloff (Height, Slope, Curvature) -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasFalloff}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Min Falloff" />
                        <Slider Minimum="{Binding FalloffSliderMinimum}" Maximum="{Binding FalloffSliderMaximum}" SmallChange="{Binding FalloffSliderSmallChange}" Value="{Binding MinFalloff}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" Text="{Binding MinFalloffDisplay, Mode=TwoWay}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasFalloff}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Max Falloff" />
                        <Slider Minimum="{Binding FalloffSliderMinimum}" Maximum="{Binding FalloffSliderMaximum}" SmallChange="{Binding FalloffSliderSmallChange}" Value="{Binding MaxFalloff}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" Text="{Binding MaxFalloffDisplay, Mode=TwoWay}" VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- Radius (Curvature only) -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasRadius}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Radius" />
                        <Slider Minimum="0.1" Maximum="10" Value="{Binding Radius}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding Radius, StringFormat='{}{0:F1}'}" VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- Angle (Direction only) -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasAngle}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Angle (deg)" />
                        <Slider Minimum="-180" Maximum="180" Value="{Binding AngleDegrees}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding AngleDegrees, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasAngle}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Angle Range (deg)" />
                        <Slider Minimum="0" Maximum="180" Value="{Binding AngleRangeDegrees}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding AngleRangeDegrees, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>

                    <!-- Noise parameters -->
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasScale}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Scale" />
                        <Slider Minimum="0.001" Maximum="1" Value="{Binding Scale}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding Scale, StringFormat='{}{0:F3}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasOffset}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Offset X" />
                        <Slider Minimum="-1000" Maximum="1000" Value="{Binding OffsetX}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding OffsetX, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasOffset}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Offset Y" />
                        <Slider Minimum="-1000" Maximum="1000" Value="{Binding OffsetY}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding OffsetY, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasSeed}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Seed" />
                        <Slider Minimum="0" Maximum="10000" Value="{Binding Seed}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding Seed, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>
                    <Grid ColumnDefinitions="*,48" ColumnSpacing="8" IsVisible="{Binding HasOctaves}">
                      <StackPanel Spacing="2">
                        <TextBlock Classes="fieldLabel" Text="Octaves" />
                        <Slider Minimum="1" Maximum="8" Value="{Binding Octaves}" />
                      </StackPanel>
                      <TextBox Grid.Column="1" Classes="valueBox" IsReadOnly="True" Text="{Binding Octaves, StringFormat='{}{0:F0}'}" VerticalAlignment="Bottom" />
                    </Grid>

                  </StackPanel>
                </Border>

              </StackPanel>

            </StackPanel>
          </ScrollViewer>

          <!-- Action Footer -->
          <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource EditorInspectorHeaderBrush}" BorderBrush="{DynamicResource EditorPanelBorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,*">
              <Button Classes="outlineButton" Content="Reset" />
              <Button Grid.Column="1" Classes="primaryButton" Content="Apply" />
            </Grid>
          </Border>
        </Grid>
      </Border>

    </Grid>
  </DockPanel>
</Window>
