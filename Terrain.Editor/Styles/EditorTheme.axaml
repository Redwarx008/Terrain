<Styles
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <!-- Metro Light Surface Palette (from HTML design) -->
    <SolidColorBrush x:Key="EditorWindowBackgroundBrush" Color="#FBF9F8" />
    <SolidColorBrush x:Key="EditorChromeBackgroundBrush" Color="#F1F3F5" />
    <SolidColorBrush x:Key="EditorPanelBackgroundBrush" Color="#FBF9F8" />
    <SolidColorBrush x:Key="EditorPanelAltBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="EditorPanelBorderBrush" Color="#C0C7D4" />
    <SolidColorBrush x:Key="EditorPanelBorderStrongBrush" Color="#A0A8B4" />
    <SolidColorBrush x:Key="EditorViewportBackgroundBrush" Color="#DCD9D9" />
    <SolidColorBrush x:Key="EditorTextPrimaryBrush" Color="#1B1C1C" />
    <SolidColorBrush x:Key="EditorTextSecondaryBrush" Color="#5F6161" />
    <SolidColorBrush x:Key="EditorAccentBrush" Color="#005FAA" />
    <SolidColorBrush x:Key="EditorAccentDarkBrush" Color="#004883" />
    <SolidColorBrush x:Key="EditorAccentSoftBrush" Color="#D3E3FF" />
    <SolidColorBrush x:Key="EditorSelectionBrush" Color="#D3E3FF" />
    <SolidColorBrush x:Key="EditorStatusBarBrush" Color="#F0EDED" />
    <SolidColorBrush x:Key="EditorCommandBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="EditorSurfaceBrush" Color="#FBF9F8" />
    <SolidColorBrush x:Key="EditorSurfaceHoverBrush" Color="#E4E2E1" />
    <SolidColorBrush x:Key="EditorModeHoverBrush" Color="#E4E2E1" />
    <SolidColorBrush x:Key="EditorModeHoverBorderBrush" Color="#005FAA" />
    <SolidColorBrush x:Key="EditorPanelAltBorderBrush" Color="#C0C7D4" />
    <SolidColorBrush x:Key="EditorGlyphMutedBrush" Color="#717783" />
    <SolidColorBrush x:Key="EditorGlyphDimBrush" Color="#717783" />
    <SolidColorBrush x:Key="EditorModeLabelBrush" Color="#5F6161" />
    <SolidColorBrush x:Key="EditorToolLabelBrush" Color="#404752" />
    <SolidColorBrush x:Key="EditorCloseGlyphBrush" Color="#717783" />
    <SolidColorBrush x:Key="EditorTitleTextBrush" Color="#1B1C1C" />
    <SolidColorBrush x:Key="EditorWindowButtonHoverBrush" Color="#E4E2E1" />
    <SolidColorBrush x:Key="EditorWindowButtonIconBrush" Color="#1B1C1C" />
    <SolidColorBrush x:Key="EditorWindowCloseBrush" Color="#C75050" />
    <SolidColorBrush x:Key="EditorTrackBackgroundBrush" Color="#E4E2E1" />
    <SolidColorBrush x:Key="EditorAxisXBrush" Color="#E14C4C" />
    <SolidColorBrush x:Key="EditorAxisYBrush" Color="#4FA558" />
    <SolidColorBrush x:Key="EditorAxisZBrush" Color="#3487E5" />
    <SolidColorBrush x:Key="EditorCategoryHoverBrush" Color="#E4E2E1" />
    <SolidColorBrush x:Key="EditorToolHoverBrush" Color="#E4E2E1" />
    <SolidColorBrush x:Key="EditorToolHoverBorderBrush" Color="#005FAA" />
    <SolidColorBrush x:Key="EditorViewportDarkBackgroundBrush" Color="#4B4C54" />
    <SolidColorBrush x:Key="EditorViewportDarkBorderBrush" Color="#61646E" />
    <SolidColorBrush x:Key="EditorAppIconBackgroundBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="EditorAppIconBorderBrush" Color="#0060AB" />
    <SolidColorBrush x:Key="EditorAppIconBlueBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="EditorAppIconGreenBrush" Color="#A3C9FF" />
    <SolidColorBrush x:Key="EditorStatusGreenBrush" Color="#4DB24D" />
    <!-- Additional Metro Light brushes -->
    <SolidColorBrush x:Key="EditorSideNavBackgroundBrush" Color="#F1F3F5" />
    <SolidColorBrush x:Key="EditorSideNavBorderBrush" Color="#C0C7D4" />
    <SolidColorBrush x:Key="EditorSideNavActiveBackgroundBrush" Color="#D3E3FF" />
    <SolidColorBrush x:Key="EditorSideNavActiveTextBrush" Color="#005FAA" />
    <SolidColorBrush x:Key="EditorInspectorHeaderBrush" Color="#F6F3F2" />
    <SolidColorBrush x:Key="EditorSectionHeaderBrush" Color="#EAE8E7" />
    <SolidColorBrush x:Key="EditorToolGridSelectedBrush" Color="#D3E3FF" />
    <SolidColorBrush x:Key="EditorToolGridSelectedBorderBrush" Color="#005FAA" />
    <SolidColorBrush x:Key="EditorToolGridBackgroundBrush" Color="#F0EDED" />
    <SolidColorBrush x:Key="EditorToolGridHoverBrush" Color="#E4E2E1" />
    <SolidColorBrush x:Key="EditorAssetTabBackgroundBrush" Color="#F6F3F2" />
    <SolidColorBrush x:Key="EditorAssetTabActiveBackgroundBrush" Color="#FBF9F8" />
    <SolidColorBrush x:Key="EditorValueBoxBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="EditorSliderAccentBrush" Color="#005FAA" />
    <SolidColorBrush x:Key="EditorViewportToolbarBrush" Color="#FBF9F8" />
    <SolidColorBrush x:Key="EditorOverlayMutedBrush" Color="#717783" />
    <Thickness x:Key="EditorPanelPadding">12</Thickness>
    <CornerRadius x:Key="EditorCornerRadius">2</CornerRadius>
  </Styles.Resources>

  <!-- Window -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource EditorWindowBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="Inter, Segoe UI" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- Title Bar -->
  <Style Selector="Border.titleBar">
    <Setter Property="Background" Value="{DynamicResource EditorChromeBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Height" Value="40" />
  </Style>

  <Style Selector="TextBlock.titleBarText">
    <Setter Property="FontFamily" Value="Inter, Segoe UI" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTitleTextBrush}" />
  </Style>

  <!-- Toolbar Row (second header row) -->
  <Style Selector="Border.toolbarRow">
    <Setter Property="Background" Value="#F6F3F2" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8,0" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Height" Value="40" />
  </Style>

  <!-- Toolbar nav buttons (File, Edit, View, etc.) -->
  <Style Selector="Border.toolbarRow Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Border.toolbarRow Button:pointerover">
    <Setter Property="Background" Value="#E4E2E1" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Border.toolbarRow Button:pressed">
    <Setter Property="Background" Value="#DCD9D9" />
  </Style>

  <!-- Menu -->
  <Style Selector="Menu.mainMenu">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Height" Value="40" />
  </Style>

  <Style Selector="Menu.mainMenu MenuItem">
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextPrimaryBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Menu.mainMenu MenuItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceHoverBrush}" />
  </Style>

  <Style Selector="Menu.mainMenu MenuItem.highlightMenu">
    <Setter Property="Foreground" Value="{DynamicResource EditorAccentBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <!-- Panels -->
  <Style Selector="Border.editorPanel">
    <Setter Property="Background" Value="{DynamicResource EditorPanelBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Border.modePanel">
    <Setter Property="Background" Value="{DynamicResource EditorSideNavBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorSideNavBorderBrush}" />
  </Style>

  <Style Selector="Border.viewportPanel">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
  </Style>

  <Style Selector="Border.inspectorPanel">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
  </Style>

  <Style Selector="Border.assetBrowserPanel">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
  </Style>

  <Style Selector="Border.inspectorSection">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="0,12,0,0" />
  </Style>

  <Style Selector="Border.statusBar">
    <Setter Property="Background" Value="{DynamicResource EditorStatusBarBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <!-- TextBlock Styles -->
  <Style Selector="TextBlock.sectionTitle">
    <Setter Property="FontFamily" Value="Inter, Segoe UI" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="600" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.modeCloseGlyph">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource EditorCloseGlyphBrush}" />
  </Style>

  <Style Selector="TextBlock.inspectorLabel">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
  </Style>

  <Style Selector="TextBlock.inspectorSectionLabel">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
    <Setter Property="Text" Value="Dummy" />
  </Style>

  <Style Selector="TextBlock.panelHint">
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="TextBlock.fieldLabel">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.modeLabel">
    <Setter Property="FontFamily" Value="Inter, Segoe UI" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{DynamicResource EditorModeLabelBrush}" />
  </Style>

  <Style Selector="TextBlock.modeIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="24" />
    <Setter Property="Foreground" Value="{DynamicResource EditorGlyphMutedBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.toolbarIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextPrimaryBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.toolbarText">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.assetCategoryIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource EditorGlyphMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.toolIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextPrimaryBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.toolLabel">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource EditorToolLabelBrush}" />
  </Style>

  <Style Selector="TextBlock.cubeIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="Foreground" Value="{DynamicResource EditorOverlayMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.chevronIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.viewToggleIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="Foreground" Value="{DynamicResource EditorOverlayMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.assetPreviewGlyph">
    <Setter Property="FontFamily" Value="Segoe UI Semibold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.assetListGlyph">
    <Setter Property="FontFamily" Value="Segoe UI Semibold" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.valueText">
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <Style Selector="TextBlock.unitText">
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="TextBlock.axisX">
    <Setter Property="Foreground" Value="{DynamicResource EditorAxisXBrush}" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.axisY">
    <Setter Property="Foreground" Value="{DynamicResource EditorAxisYBrush}" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.axisZ">
    <Setter Property="Foreground" Value="{DynamicResource EditorAxisZBrush}" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <!-- Button Styles -->
  <Style Selector="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceHoverBrush}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{DynamicResource EditorAccentSoftBrush}" />
  </Style>

  <Style Selector="Button.commandButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="MinWidth" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Button.commandButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceHoverBrush}" />
  </Style>

  <Style Selector="Button.windowButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinWidth" Value="46" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Button.windowButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorWindowButtonHoverBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.windowButton.closeButton">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.windowButton.closeButton TextBlock.windowButtonIcon">
    <Setter Property="Foreground" Value="{DynamicResource EditorSurfaceBrush}" />
  </Style>

  <Style Selector="Button.windowButton.closeButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorWindowCloseBrush}" />
  </Style>

  <Style Selector="Button.windowButton.closeButton:pointerover TextBlock.windowButtonIcon">
    <Setter Property="Foreground" Value="{DynamicResource EditorSurfaceBrush}" />
  </Style>

  <Style Selector="TextBlock.windowButtonIcon">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="Foreground" Value="{DynamicResource EditorWindowButtonIconBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.iconSquareButton">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.commandDivider">
    <Setter Property="Width" Value="1" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Background" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox.metroCombo">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <!-- TextBox -->
  <Style Selector="TextBox.searchBox">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="TextBox.valueBox">
    <Setter Property="Background" Value="{DynamicResource EditorValueBoxBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="HorizontalContentAlignment" Value="Right" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <!-- CheckBox -->
  <Style Selector="CheckBox">
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Slider -->
  <Style Selector="Slider">
    <Setter Property="MinWidth" Value="80" />
  </Style>

  <Style Selector="Slider /template/ Border#TrackBackground">
    <Setter Property="Background" Value="{DynamicResource EditorTrackBackgroundBrush}" />
    <Setter Property="Height" Value="4" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Slider /template/ Border#TrackFill">
    <Setter Property="Background" Value="{DynamicResource EditorSliderAccentBrush}" />
    <Setter Property="Height" Value="4" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Slider /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorAccentBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <!-- Mode ListBox (SideNav style) -->
  <Style Selector="ListBox.modeList">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.modeList > ListBoxItem">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0,12" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="2,0,0,0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="ListBox.modeList > ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorModeHoverBrush}" />
  </Style>

  <Style Selector="ListBox.modeList > ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource EditorSideNavActiveBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorSideNavActiveTextBrush}" />
  </Style>

  <Style Selector="ListBox.modeList > ListBoxItem:selected TextBlock.modeLabel">
    <Setter Property="Foreground" Value="{DynamicResource EditorSideNavActiveTextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="ListBox.modeList > ListBoxItem:selected TextBlock.modeIcon">
    <Setter Property="Foreground" Value="{DynamicResource EditorSideNavActiveTextBrush}" />
  </Style>

  <!-- Tool ListBox (Grid style) -->
  <Style Selector="ListBox.toolList">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.toolList > ListBoxItem">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource EditorToolGridBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="ListBox.toolList > ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorToolGridHoverBrush}" />
  </Style>

  <Style Selector="ListBox.toolList > ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource EditorToolGridSelectedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorToolGridSelectedBorderBrush}" />
  </Style>

  <Style Selector="ListBox.toolList > ListBoxItem:selected TextBlock.toolIcon">
    <Setter Property="Foreground" Value="{DynamicResource EditorAccentBrush}" />
  </Style>

  <!-- Asset Category ListBox -->
  <Style Selector="ListBox.assetCategoryList">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.assetCategoryList > ListBoxItem">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="10,7" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBox.assetCategoryList > ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorCategoryHoverBrush}" />
  </Style>

  <Style Selector="ListBox.assetCategoryList > ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource EditorSelectionBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorAccentBrush}" />
  </Style>

  <!-- Asset Tile ListBox -->
  <Style Selector="ListBox.assetTileList">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.assetTileList > ListBoxItem">
    <Setter Property="Margin" Value="0,0,8,8" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.assetTile">
    <Setter Property="Background" Value="{DynamicResource EditorPanelAltBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="ListBox.assetTileList > ListBoxItem:pointerover Border.assetTile">
    <Setter Property="BorderBrush" Value="{DynamicResource EditorAccentBrush}" />
  </Style>

  <Style Selector="ListBox.assetTileList > ListBoxItem:selected Border.assetTile">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorAccentBrush}" />
  </Style>

  <Style Selector="Border.assetPreview">
    <Setter Property="Background" Value="{DynamicResource EditorViewportBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="2,2,0,0" />
  </Style>

  <!-- Asset List ListBox -->
  <Style Selector="ListBox.assetListView">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.assetListView > ListBoxItem">
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="Margin" Value="0,0,0,5" />
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="ListBox.assetListView > ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorAccentBrush}" />
  </Style>

  <Style Selector="Border.assetListPreview">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.brushPreviewFrame">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Background" Value="{DynamicResource EditorToolGridBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Border.materialPreviewCard">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Border.materialSwatch">
    <Setter Property="Width" Value="46" />
    <Setter Property="Height" Value="34" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- Action Footer Buttons -->
  <Style Selector="Button.outlineButton">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <Style Selector="Button.outlineButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceHoverBrush}" />
  </Style>

  <Style Selector="Button.primaryButton">
    <Setter Property="Background" Value="{DynamicResource EditorAccentBrush}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <Style Selector="Button.primaryButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorAccentDarkBrush}" />
  </Style>

  <!-- Asset Tab Button -->
  <Style Selector="Button.assetTab">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Height" Value="28" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="2,2,0,0" />
  </Style>

  <Style Selector="Button.assetTab:pointerover">
    <Setter Property="Background" Value="{DynamicResource EditorSurfaceHoverBrush}" />
  </Style>

  <Style Selector="Button.assetTabActive">
    <Setter Property="Background" Value="{DynamicResource EditorAssetTabActiveBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="1,0,1,0" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Height" Value="28" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource EditorAccentBrush}" />
    <Setter Property="CornerRadius" Value="2,2,0,0" />
  </Style>

  <!-- Viewport Toolbar -->
  <Style Selector="Border.viewportToolbar">
    <Setter Property="Background" Value="{DynamicResource EditorViewportToolbarBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Height" Value="36" />
  </Style>

  <!-- Inspector Header -->
  <Style Selector="Border.inspectorHeader">
    <Setter Property="Background" Value="{DynamicResource EditorInspectorHeaderBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource EditorPanelBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Height" Value="40" />
  </Style>

  <!-- Section Label -->
  <Style Selector="TextBlock.sectionLabel">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource EditorTextSecondaryBrush}" />
  </Style>
</Styles>
