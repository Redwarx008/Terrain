<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <OutputType>WinExe</OutputType>
    <RootNamespace>Terrain.Editor</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <OutputPath>..\Bin\Editor\$(Configuration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
    <PackageReference Include="Stride.Engine" Version="4.3.0.2507" />
    <PackageReference Include="Stride.Video" Version="4.3.0.2507" />
    <PackageReference Include="Stride.Physics" Version="4.3.0.2507" />
    <PackageReference Include="Stride.Navigation" Version="4.3.0.2507" />
    <PackageReference Include="Stride.Particles" Version="4.3.0.2507" />
    <PackageReference Include="Stride.UI" Version="4.3.0.2507" />
    <PackageReference Include="Stride.Core.Assets.CompilerApp" Version="4.3.0.2507" IncludeAssets="build;buildTransitive" />
    <PackageReference Include="Stride.CommunityToolkit.ImGui" Version="1.0.0-preview.62" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Terrain\Terrain.csproj" />
    <ProjectReference Include="..\TerrainPreProcessor\TerrainPreProcessor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Shared\VirtualTextureLayout.cs" Link="Shared\VirtualTextureLayout.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Effects\EditorTerrainDiffuse.sdsl.cs">
      <DesignTime>True</DesignTime>
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="Effects\EditorTerrainDisplacement.sdsl.cs">
      <DesignTime>True</DesignTime>
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="Effects\EditorTerrainForwardShadingEffect.sdfx.cs">
      <DesignTime>True</DesignTime>
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="Effects\EditorTerrainHeightParameters.sdsl.cs">
      <DesignTime>True</DesignTime>
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="Effects\EditorTerrainHeightStream.sdsl.cs">
      <DesignTime>True</DesignTime>
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="Effects\EditorTerrainDiffuse.sdsl">
      <LastGenOutput>EditorTerrainDiffuse.sdsl.cs</LastGenOutput>
    </None>
    <None Update="Effects\EditorTerrainDisplacement.sdsl">
      <LastGenOutput>EditorTerrainDisplacement.sdsl.cs</LastGenOutput>
    </None>
    <None Update="Effects\EditorTerrainForwardShadingEffect.sdfx">
      <LastGenOutput>EditorTerrainForwardShadingEffect.sdfx.cs</LastGenOutput>
    </None>
    <None Update="Effects\EditorTerrainHeightParameters.sdsl">
      <LastGenOutput>EditorTerrainHeightParameters.sdsl.cs</LastGenOutput>
    </None>
    <None Update="Effects\EditorTerrainHeightStream.sdsl">
      <LastGenOutput>EditorTerrainHeightStream.sdsl.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
